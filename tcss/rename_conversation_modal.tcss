RenameConversationModal {
  align: center middle;
}

#renameDialog {
  width: 60;
  height: auto;
  padding: 1 2;
  border: thick $warning;
  background: $surface;
}

#renameDialog Label {
  width: 1fr;
  content-align: center middle;
  padding-bottom: 1;
}

#renameButtons {
  width: 1fr;
  height: auto;
  align-horizontal: center;
}

#button_generateName {
  width: 1fr;
  margin-bottom: 1;
}
